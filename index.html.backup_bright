    s:[{t:'站起来从手开始甩', h:'',   d:8},{t:'手臂一起甩',        h:'',   d:8},{t:'全身都抖起来',     h:'',   d:12},{t:'慢慢停下深呼吸',   h:'',   d:6}]},
  {i:'yawn2',   n:'哈欠深呼吸',  ic:'😮',  t:'1min',  c:'night',   type:'routine',
    s:[{t:'张嘴打一个大哈欠', h:'',   d:6},{t:'用力吞咽口水',       h:'',   d:4},{t:'伸个懒腰',         h:'',   d:6},{t:'再打哈欠再吞咽',   h:'',   d:6},{t:'深呼吸放松',       h:'',   d:6}]},
  {i:'finger',  n:'指尖对碰',    ic:'🤏',  t:'2min',  c:'am',      type:'routine',
    s:[{t:'拇指依次碰食中无名小指',h:'右手先做', d:12},{t:'换左手',            h:'',   d:12},{t:'左右手同时',       h:'',   d:12},{t:'闭眼再做',         h:'',   d:12},{t:'抖抖手放松',       h:'',   d:4}]},
  {i:'rubber',  n:'橡皮筋拉伸',  ic:'🪢',  t:'2min',  c:'am',      type:'routine', no:'需橡皮筋',
    s:[{t:'指尖套橡皮筋',     h:'',   d:0},{t:'拇指食指撑开',       h:'',   d:12},{t:'拇指中指撑开',     h:'',   d:12},{t:'拇指无名指撑开',   h:'',   d:12},{t:'拇指小指撑开',     h:'',   d:12},{t:'换左手重复',       h:'',   d:20}]},
];

const DEF_CATS = [
  {i:'morning',ic:'☀️', n:'早晨'},
  {i:'am',     ic:'🌤️', n:'上午'},
  {i:'pm',     ic:'🏃',  n:'下午'},
  {i:'night',  ic:'🌙', n:'睡前'},
];

// ===== 数据管理 =====
let DC = {}; // { cats: [], items: [], settings: {userName: ''} }

function initDC(){
  const catsRaw = localStorage.getItem('dc_categories');
  if(!catsRaw){
    // First visit: import defaults
    DC.cats = JSON.parse(JSON.stringify(DEF_CATS));
    DC.items = JSON.parse(JSON.stringify(DEF_ITEMS));
    DC.settings = {userName: '小伙伴'};
    flushDC();
    return;
  }
  DC.cats = JSON.parse(catsRaw);
  DC.items = JSON.parse(localStorage.getItem('dc_items') || '[]');
  try{ DC.settings = JSON.parse(localStorage.getItem('dc_settings') || '{}'); }catch(e){ DC.settings = {}; }
  if(!DC.settings.userName) DC.settings.userName = '小伙伴';
}

function flushDC(){
  localStorage.setItem('dc_categories', JSON.stringify(DC.cats));
  localStorage.setItem('dc_items', JSON.stringify(DC.items));
  localStorage.setItem('dc_settings', JSON.stringify(DC.settings));
}

function getItemsByCat(catId){
  return DC.items.filter(x => x.c === catId);
}

function getCat(id){
  return DC.cats.find(c => c.i === id);
}

function getItem(id){
  return DC.items.find(x => x.i === id);
}

// ===== 每日完成记录 =====
function dk(){
  const d = new Date();
  return d.getFullYear()+'-'+(d.getMonth()+1)+'-'+d.getDate();
}

let Dn = [];

function loadDn(){
  try{
    const r = localStorage.getItem('dc_'+dk());
    if(r) Dn = JSON.parse(r);
    else Dn = [];
  }catch(e){ Dn = []; }
}

function svDn(){
  localStorage.setItem('dc_'+dk(), JSON.stringify(Dn));
}

// ===== 状态 =====
let St={pi:'morning',dn:[],ex:null,cy:1,cs:1,st:-1,ss:[],pl:false,ti:null,rm:0};

// ===== 首页渲染 =====
function swT(id){
  St.pi = id;
  rH();
}

function rH(){
  // Render greeting
  const grTxt = document.getElementById('grTxt');
  grTxt.textContent = '🌅 早上好，' + (DC.settings.userName || '小伙伴');

  // Render tags
  const tgS = document.getElementById('tgS');
  tgS.innerHTML = DC.cats.map(c =>
    `<div class="tagb ${c.i===St.pi?'ac':''}" data-i="${c.i}" onclick="swT('${c.i}')">${c.ic} ${c.n}</div>`
  ).join('');
  if(DC.cats.length===0){
    tgS.innerHTML = '<div style="color:#5a7a98;font-size:.8125rem;padding:.25rem 0;">暂无分类，请前往管理页创建</div>';
  }

  // Render items
  const items = getItemsByCat(St.pi);
  const l = document.getElementById('exL');
  l.innerHTML = items.map(x => {
    const done = Dn.includes(x.i);
    const tpLabel = x.type==='simple' ? '纯打卡' : '跟练型';
    return `<div class="ex ${done?'done':''}" onclick="sX('${x.i}')">
      <div class="ck">${done?'✓':''}</div><div class="ic">${x.ic}</div>
      <div class="inf">${x.n} <span class="s">${x.no||(getCat(x.c)||{}).n||''} · ${x.t||''}</span></div>
      <span class="tp">${tpLabel}</span>
      <div class="tm ${done?'done':''}">${done?'✅ 已完成':(x.t||'')}</div></div>`;
  }).join('');
  if(items.length===0){
    l.innerHTML = '<div class="empty-state">这个分类下还没有打卡项目<br><span style="font-size:.75rem;">去管理页创建或切换到其他分类</span></div>';
  }

  upPr();
}

function upPr(){
  const items = getItemsByCat(St.pi);
  const t = items.length;
  const d = items.filter(x => Dn.includes(x.i)).length;
  document.getElementById('pgN').textContent = `${d} / ${t}`;
  document.getElementById('pgB').style.width = `${t>0 ? d/t*100 : 0}%`;
  const doneItems = items.filter(x => Dn.includes(x.i)).map(x => x.ic + x.n).join(' · ');
  document.getElementById('pgT').textContent = d === t && t > 0 ? '🎉 全部完成！' : (doneItems ? '✅ ' + doneItems : '点击打卡项开始');
}

// ===== 进入练习 =====
function sX(id){
  const x = getItem(id);
  if(!x) return;

  // Simple type: complete directly
  if(x.type === 'simple'){
    if(!Dn.includes(id)) Dn.push(id);
    svDn();
    rH();
    // Show completion popup
    const allDone = getItemsByCat(St.pi).every(it => Dn.includes(it.i));
    document.getElementById('ol').classList.add('show');
    document.getElementById('olT').textContent = `${x.ic} ${x.n} 完成！`;
    document.getElementById('olS').textContent = allDone ? '🎉 今日全部完成！' : '继续加油 💪';
    const det = getItemsByCat(St.pi).map(it => (Dn.includes(it.i)?'✅':'⬜')+' '+it.ic+it.n).join('<br>');
    document.getElementById('olD').innerHTML = '今日进度：' + getItemsByCat(St.pi).filter(it=>Dn.includes(it.i)).length + '/' + getItemsByCat(St.pi).length + '<br>' + det;
    return;
  }

  // Routine type: go to practice page
  St.ex = x;
  St.cs = x.cy || 1;
  St.cy = 1;
  St.st = -1;
  St.ss = x.s || [];
  St.pl = false;
  if(St.ti){ clearInterval(St.ti); St.ti = null; }

  document.getElementById('pEn').textContent = x.ic + ' ' + x.n;
  document.getElementById('pIf').textContent = (getCat(x.c)||{}).n||'' + ' · 约' + (x.t||'');
  document.getElementById('pH').classList.remove('active');
  document.getElementById('pP').classList.add('active');
  uPpd();
  uP();
}

function uPpd(){
  const items = getItemsByCat(St.pi);
  const d = items.filter(it => Dn.includes(it.i)).length;
  document.getElementById('pPd').textContent = d+'/'+items.length;
}

// ===== 跟练状态更新 =====
function uP(){
  if(!St.ex)return; const x=St.ex; const m=St.cs>1;
  const sn=document.getElementById('pSn'),st=document.getElementById('pSt'),sc=document.getElementById('pSc');
  const tn=document.getElementById('pTim'),tl=document.getElementById('pTimL'),btn=document.getElementById('pBtn');
  if(St.st===-1){
    sn.textContent='准备';st.innerHTML=''+(m?`第${St.cy}/${St.cs}轮 `:'')+St.ss[0].t;
    sc.textContent=St.ss[0].h?'💡 '+St.ss[0].h:'';
    tn.textContent='';tl.textContent='';
    btn.textContent='▶ 开始';btn.disabled=false;
    dr(0.15);rD(1,0);return;
  }
  const s=St.ss[St.st];
  sn.textContent=(m?`第${St.cy}轮·`:'')+'步'+(St.st+1)+'/'+St.ss.length;
  st.innerHTML=s.t;
  sc.innerHTML=(s.h?'💡 '+s.h:'')+(x.no&&St.st===0?`<br><span class="tg2">📌 ${x.no}</span>`:'');
  if(s.d>0){tn.textContent=St.pl?St.rm:s.d;tl.textContent='秒';}else{tn.textContent='';tl.textContent='';}
  if(m)rD(St.cs,St.cy-1);else rD(St.ss.length,St.st);
  if(St.pl){btn.textContent='⏳ 进行中...';btn.disabled=true;}else{btn.textContent='▶ 下一步';btn.disabled=false;}
  let ra=0.15;if(St.st>=1&&St.st<=2)ra=St.pl?0.3+0.7*(1-St.rm/s.d):1;
  dr(Math.max(0.15,Math.min(1,ra)));
}

function rD(n,a){
  const c=document.getElementById('pDt');
  c.innerHTML=Array.from({length:n},(_,i)=>{
    let cl='';if(i<a)cl=' dn';else if(i===a)cl=' act';
    return `<div class="${cl}"></div>`;
  }).join('');
}

function dr(sp){
  const c=document.getElementById('pc'),ctx=c.getContext('2d');
  const w=c.width,h=c.height,cx=w/2,cy=h/2;ctx.clearRect(0,0,w,h);
  const aa=30+60*sp,la=15+40*sp;
  ctx.beginPath();ctx.arc(cx,cy,72,0,Math.PI*2);
  ctx.fillStyle='rgba(79,195,247,0.04)';ctx.fill();
  const hy=cy-42-8*(1-sp);
  ctx.save();
  ctx.beginPath();ctx.ellipse(cx,hy+26,10,18,0,0,Math.PI*2);
  ctx.fillStyle='#4fc3f7';ctx.fill();
  ctx.beginPath();ctx.arc(cx,hy,13,0,Math.PI*2);
  ctx.fillStyle='#4fc3f7';ctx.fill();
  ctx.fillStyle='#0f1923';
  ctx.beginPath();ctx.arc(cx-4,hy,1.8,0,Math.PI*2);
  ctx.arc(cx+4,hy,1.8,0,Math.PI*2);ctx.fill();
  ctx.beginPath();ctx.arc(cx,hy+4,4,0.1*Math.PI,0.9*Math.PI);
  ctx.strokeStyle='#0f1923';ctx.lineWidth=1.3;ctx.stroke();
  const sy=hy+14;ctx.strokeStyle='#4fc3f7';ctx.lineWidth=6;ctx.lineCap='round';
  let lx=cx-10-50*Math.cos((90-aa)*Math.PI/180)*sp,ly=sy-6+50*Math.sin((90-aa)*Math.PI/180)*sp;
  ctx.beginPath();ctx.moveTo(cx-10,sy);ctx.lineTo(lx,ly);ctx.stroke();
  let rx=cx+10+50*Math.cos((90-aa)*Math.PI/180)*sp,ry=sy-6+50*Math.sin((90-aa)*Math.PI/180)*sp;
  ctx.beginPath();ctx.moveTo(cx+10,sy);ctx.lineTo(rx,ry);ctx.stroke();
  const hy2=hy+44;
  lx=cx-5-36*Math.cos((90-la)*Math.PI/180)*sp;ly=hy2+36*Math.sin((90-la)*Math.PI/180)*sp;
  ctx.beginPath();ctx.moveTo(cx-5,hy2);ctx.lineTo(lx,ly);ctx.stroke();
  rx=cx+5+36*Math.cos((90-la)*Math.PI/180)*sp;ry=hy2+36*Math.sin((90-la)*Math.PI/180)*sp;
  ctx.beginPath();ctx.moveTo(cx+5,hy2);ctx.lineTo(rx,ry);ctx.stroke();
  ctx.restore();
}

// ===== 计时器 =====
document.getElementById('pBtn').addEventListener('click',()=>{
  if(!St.ex)return;
  if(St.st===-1){St.st=0;St.cy=1;uP();if(St.ss[0]&&St.ss[0].d>0)sT();return;}
  if(!St.pl)sT();
});

function sT(){
  const s=St.ss[St.st];if(!s||s.d<=0){ad();return;}
  St.rm=s.d;St.pl=true;uP();
  St.ti=setInterval(()=>{
    St.rm--;uP();
    if(St.rm<=0){clearInterval(St.ti);St.ti=null;St.pl=false;ad();}
  },1000);
}

function ad(){
  St.st++;St.pl=false;
  if(St.st>=St.ss.length){
    if(St.cy>=St.cs){fEx();return;}
    St.cy++;St.st=0;
  }
  uP();
  if(St.st<St.ss.length&&St.ss[St.st].d>0)sT();
}

function doneP(){fEx();}

// ===== 完成 =====
function fEx(){
  const id = St.ex.i;
  if(!Dn.includes(id)) Dn.push(id);
  svDn();
  const items = getItemsByCat(St.pi);
  const allDone = items.every(x => Dn.includes(x.i));
  document.getElementById('ol').classList.add('show');
  document.getElementById('olT').textContent = `${St.ex.ic} ${St.ex.n} 完成！`;
  document.getElementById('olS').textContent = allDone ? '🎉 今日全部完成！' : '继续加油，还有练习等着你 💪';
  const det = items.map(x => (Dn.includes(x.i)?'✅':'⬜')+' '+x.ic+x.n).join('<br>');
  document.getElementById('olD').innerHTML = '今日进度：'+items.filter(x=>Dn.includes(x.i)).length+'/'+items.length+'<br>'+det;
}

function resetP(){clOl();if(St.ti){clearInterval(St.ti);St.ti=null;}if(St.ex){St.st=-1;St.cy=1;St.pl=false;St.rm=0;uP();}}

// ===== 弹窗控制 =====
function clOl(){document.getElementById('ol').classList.remove('show');}
function goH(){clOl();clCf();if(St.ti){clearInterval(St.ti);St.ti=null;}document.getElementById('pP').classList.remove('active');document.getElementById('pM').classList.remove('active');document.getElementById('pME').classList.remove('active');document.getElementById('pH').classList.add('active');rH();}
function cfExit(){document.getElementById('cf').classList.add('show');}
function clCf(){document.getElementById('cf').classList.remove('show');}
function doExit(){clCf();goH();}

// ===== 姓名编辑 =====
function openNE(){
  document.getElementById('neInput').value = DC.settings.userName || '';
  document.getElementById('ne').classList.add('show');
  setTimeout(()=>document.getElementById('neInput').focus(),100);
}
function clNE(){document.getElementById('ne').classList.remove('show');}
function saveNE(){
  const v = document.getElementById('neInput').value.trim();
  if(v){
    DC.settings.userName = v;
    flushDC();
    rH();
  }
  clNE();
}

// ===== 删除确认 =====
let delCallback = null;
function showDC(title, subtitle, cb){
  document.getElementById('dcT').textContent = title;
  document.getElementById('dcS').textContent = subtitle || '此操作不可恢复';
  delCallback = cb;
  document.getElementById('dc').classList.add('show');
}
function clDC(){document.getElementById('dc').classList.remove('show'); delCallback = null;}
function doDel(){
  if(delCallback){ delCallback(); delCallback = null; }
  clDC();
}

// ===== 重置今日 =====
function resetToday(){
  showDC('重置今日打卡？', '所有今日完成记录将被清除', ()=>{
    Dn = [];
    svDn();
    rH();
  });
}

// ===== 管理页 =====
function openMg(){
  document.getElementById('pH').classList.remove('active');
  document.getElementById('pM').classList.add('active');
  rMg();
}

function swMg(tab){
  document.querySelectorAll('.mg-tab').forEach(t => t.classList.toggle('ac', t.dataset.tab===tab));
  document.getElementById('mgItems').style.display = tab==='items' ? 'block' : 'none';
  document.getElementById('mgCats').style.display = tab==='cats' ? 'block' : 'none';
  if(tab==='items') rMgItems();
  else rMgCats();
}

function rMg(){
  swMg('items');
}

function rMgItems(){
  const l = document.getElementById('mgItemList');
  l.innerHTML = DC.items.map(x => {
    const cn = (getCat(x.c)||{}).n || '(无分类)';
    const tp = x.type==='simple' ? '纯打卡' : '跟练型';
    return `<div class="mg-item">
      <div class="ic">${x.ic}</div>
      <div class="inf">
        <div class="n">${x.n}</div>
        <div class="det">${tp} · ${cn} · ${x.t||''}</div>
      </div>
      <div class="mg-acts">
        <span onclick="openEditor('${x.i}')">✏️</span>
        <span onclick="delItem('${x.i}')">🗑️</span>
      </div>
    </div>`;
  }).join('');
  if(DC.items.length===0){
    l.innerHTML = '<div class="empty-state">还没有打卡项目<br><span style="font-size:.75rem;">点击下方按钮新建</span></div>';
  }
}

function rMgCats(){
  const l = document.getElementById('mgCatList');
  l.innerHTML = DC.cats.map(c => {
    const cnt = DC.items.filter(x => x.c === c.i).length;
    return `<div class="mg-cat">
      <div class="ic">${c.ic}</div>
      <div class="n">${c.n} <span style="font-size:.75rem;color:#5a7a98;">(${cnt}项)</span></div>
      <span class="del" onclick="delCat('${c.i}')">🗑️</span>
    </div>`;
  }).join('');
  if(DC.cats.length===0){
    l.innerHTML = '<div class="empty-state">还没有分类，请添加</div>';
  }
}

function addCat(){
  const ic = document.getElementById('catIc').value.trim() || '📌';
  const n = document.getElementById('catN').value.trim();
  if(!n){ alert('请输入分类名称'); return; }
  const id = 'cat_'+Date.now();
  DC.cats.push({i:id, ic:ic, n:n});
  flushDC();
  document.getElementById('catIc').value = '';
  document.getElementById('catN').value = '';
  rMgCats();
  rH();
}

function delCat(id){
  const c = getCat(id);
  if(!c) return;
  const cnt = DC.items.filter(x => x.c === id).length;
  const msg = cnt > 0 ? `删除分类「${c.n}」将同时删除其下 ${cnt} 个打卡项目` : `删除分类「${c.n}」`;
  showDC('确认删除？', msg, ()=>{
    DC.items = DC.items.filter(x => x.c !== id);
    DC.cats = DC.cats.filter(x => x.i !== id);
    flushDC();
    if(St.pi === id) St.pi = DC.cats.length > 0 ? DC.cats[0].i : '';
    rMgCats();
    rMgItems();
    rH();
  });
}

function delItem(id){
  const x = getItem(id);
  if(!x) return;
  showDC(`删除「${x.n}」？`, '此操作不可恢复', ()=>{
    DC.items = DC.items.filter(it => it.i !== id);
    flushDC();
    rMgItems();
    rH();
  });
}

// ===== 项目编辑器 =====
let editingId = null;

function openEditor(id){
  editingId = id;
  const el = document.getElementById('meTitle');
  el.textContent = id ? '编辑打卡项目' : '新建打卡项目';

  // Populate category dropdown
  const sel = document.getElementById('meC');
  sel.innerHTML = DC.cats.map(c => `<option value="${c.i}">${c.ic} ${c.n}</option>`).join('');

  if(id){
    const x = getItem(id);
    if(x){
      document.getElementById('meIc').value = x.ic || '';
      document.getElementById('meN').value = x.n || '';
      document.getElementById('meC').value = x.c || (DC.cats[0]||{}).i || '';
      swType(x.type || 'simple');
      document.getElementById('meT').value = x.t || '';
      document.getElementById('meNo').value = x.no || '';
      document.getElementById('meCy').value = x.cy || 1;
      renderSteps(x.s || []);
    }
  } else {
    document.getElementById('meIc').value = '';
    document.getElementById('meN').value = '';
    document.getElementById('meC').value = (DC.cats[0]||{}).i || '';
    swType('simple');
    document.getElementById('meT').value = '';
    document.getElementById('meNo').value = '';
    document.getElementById('meCy').value = 1;
    renderSteps([]);
  }

  document.getElementById('pM').classList.remove('active');
  document.getElementById('pME').classList.add('active');
}

function closeEditor(){
  document.getElementById('pME').classList.remove('active');
  document.getElementById('pM').classList.add('active');
  rMgItems();
}

function swType(type){
  document.querySelectorAll('.me-type-btn').forEach(b => b.classList.toggle('ac', b.dataset.t===type));
  const showSteps = type === 'routine';
  document.getElementById('meSteps').style.display = showSteps ? 'block' : 'none';
  document.getElementById('meCy').parentElement.style.display = showSteps ? 'flex' : 'none';
}

// ===== 步骤编辑器 =====
let stepData = [];

function renderSteps(steps){
  stepData = steps.map((s,i) => ({...s, _k:i}));
  renderStepList();
}

function renderStepList(){
  const l = document.getElementById('meStepList');
  l.innerHTML = stepData.map((s, i) => `
    <div class="me-step">
      <div class="hdr">
        <span class="label">步骤 ${i+1}</span>
        <span class="rm" onclick="rmStep(${i})">🗑️</span>
      </div>
      <div class="sf">
        <div class="srow">
          <input class="st-name" value="${escHtml(s.t)}" placeholder="步骤名" oninput="udStep(${i},'t',this.value)">
          <input class="dur" type="number" value="${s.d}" placeholder="秒" min="0" oninput="udStep(${i},'d',Number(this.value)||0)">
        </div>
        <div class="srow">
          <input value="${escHtml(s.h||'')}" placeholder="提示（可选）" oninput="udStep(${i},'h',this.value)">
        </div>
      </div>
    </div>
  `).join('');
}

function escHtml(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function udStep(i, k, v){
  if(stepData[i]) stepData[i][k] = v;
}

function addStep(){
  stepData.push({t:'', h:'', d:10, _k:Date.now()});
  renderStepList();
}

function rmStep(i){
  stepData.splice(i,1);
  renderStepList();
}

// ===== 保存项目 =====
function saveItem(){
  const ic = document.getElementById('meIc').value.trim();
  const n = document.getElementById('meN').value.trim();
  const c = document.getElementById('meC').value;
  const t = document.getElementById('meT').value.trim();
  const no = document.getElementById('meNo').value.trim();
  const cy = parseInt(document.getElementById('meCy').value) || 1;
  const type = document.querySelector('.me-type-btn.ac').dataset.t;

  if(!n){ alert('请输入名称'); return; }
  if(!c){ alert('请选择分类'); return; }

  if(editingId){
    const x = getItem(editingId);
    if(x){
      x.ic = ic || '✅';
      x.n = n;
      x.c = c;
      x.t = t;
      x.no = no;
      x.cy = type==='routine' ? cy : undefined;
      x.type = type;
      if(type==='routine'){
        x.s = stepData.map(s => ({t:s.t, h:s.h||'', d:Number(s.d)||0}));
      } else {
        x.s = [];
        delete x.cy;
      }
    }
  } else {
    const id = 'item_'+Date.now();
    const item = {
      i: id,
      ic: ic || '✅',
      n: n,
      c: c,
      t: t,
      no: no,
      type: type
    };
    if(type==='routine'){
      item.cy = cy;
      item.s = stepData.map(s => ({t:s.t, h:s.h||'', d:Number(s.d)||0}));
    } else {
      item.s = [];
    }
    DC.items.push(item);
  }

  flushDC();
  closeEditor();
  rH();
}

// ===== 启动 =====
initDC();
loadDn();
// Use first category as default if current pi is not valid
if(!getCat(St.pi) && DC.cats.length>0) St.pi = DC.cats[0].i;
rH();
</script>
