<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>✅ 每日打卡</title>
<style>
/* ===== 根字体随屏幕宽度缩放 ===== */
html{font-size:calc(100vw / 375 * 16);}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;}
body{font-family:-apple-system,'PingFang SC','Noto Sans SC',sans-serif;background:#0f1923;color:#e8edf2;display:flex;flex-direction:column;overflow:hidden;overscroll-behavior:none;touch-action:manipulation;}

/* ===== 页面容器 ===== */
.page{display:none;flex-direction:column;min-height:100vh;}
.page.active{display:flex;}

/* ===== 首页 ===== */
.scroll{flex:1;overflow-y:auto;overflow-x:hidden;padding:1rem 1.25rem 2rem;-webkit-overflow-scrolling:touch;}
.title{font-size:1.625rem;font-weight:700;margin-bottom:.25rem;}
.hello{font-size:.9375rem;color:#7a94b0;margin-bottom:.75rem;display:flex;align-items:center;gap:.375rem;}
.hello .ne-btn{font-size:.75rem;opacity:.4;cursor:pointer;padding:.125rem .25rem;border-radius:.25rem;transition:.12s;}
.hello .ne-btn:active{opacity:1;background:#1f3348;}

/* 进度卡片 */
.pc{background:#1a2b3c;border-radius:.875rem;padding:1rem;margin-bottom:.875rem;border:1px solid #1f3348;}
.pc .r{display:flex;justify-content:space-between;font-size:.8125rem;color:#7a94b0;margin-bottom:.375rem;}
.pc .r .n{color:#4fc3f7;font-size:1.125rem;font-weight:700;}
.pb{height:.375rem;background:#1f3348;border-radius:.1875rem;overflow:hidden;margin-bottom:.375rem;}
.pb .f{height:100%;background:linear-gradient(90deg,#4fc3f7,#81d4fa);border-radius:.1875rem;transition:width .4s;}
.pc .sub{font-size:.8125rem;color:#5a7a98;}

/* 练习列表 */
.el{display:flex;flex-direction:column;gap:.5rem;}
.ex{display:flex;align-items:center;gap:.75rem;padding:.875rem;border-radius:.625rem;background:#1a2b3c;border:1px solid #1f3348;cursor:pointer;transition:.12s;}
.ex:active{background:#1f3348;transform:scale(.98);}
.ex .ck{width:1.375rem;height:1.375rem;border-radius:50%;border:2px solid #2d4c6e;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.6875rem;color:#4fc3f7;}
.ex.done .ck{border-color:#4fc3f7;background:rgba(79,195,247,.1);}
.ex .ic{font-size:1.25rem;width:1.75rem;text-align:center;flex-shrink:0;}
.ex .inf{flex:1;font-size:.9375rem;font-weight:600;}
.ex .inf .s{font-size:.8125rem;font-weight:400;color:#5a7a98;}
.ex .tm{font-size:.8125rem;color:#5a7a98;flex-shrink:0;}
.ex .tm.done{color:#4fc3f7;}
.ex .tp{font-size:.6875rem;background:#1f3348;color:#6a8aaa;padding:.0625rem .375rem;border-radius:.25rem;flex-shrink:0;}

/* 底部管理入口 */
.mg-entry{display:flex;gap:.5rem;margin-top:.75rem;justify-content:center;}
.mg-entry button{flex:1;max-width:9rem;padding:.625rem;border-radius:.625rem;border:1px solid #1f3348;background:#1a2b3c;color:#7a94b0;font-size:.8125rem;cursor:pointer;transition:.12s;}
.mg-entry button:active{background:#1f3348;color:#8aa0b8;}

/* 标签按钮 */
.tags{display:flex;gap:.375rem;margin-bottom:.875rem;overflow-x:auto;}
.tags::-webkit-scrollbar{display:none;}
.tagb{flex-shrink:0;padding:.4375rem .875rem;border-radius:1.25rem;font-size:.8125rem;background:#1a2b3c;border:1px solid #1f3348;color:#8aa0b8;cursor:pointer;white-space:nowrap;}
.tagb:active{background:#2d4c6e;}
.tagb.ac{background:#2d4c6e;border-color:#4fc3f7;color:#4fc3f7;}

/* 使用说明 */
.us{background:#1a2b3c;border-radius:.625rem;padding:.75rem .875rem;border:1px solid #1f3348;font-size:.8125rem;color:#7a94b0;margin-top:.875rem;line-height:1.6;}
.us .ut{color:#8aa0b8;font-weight:600;margin-bottom:.25rem;}

/* ===== 顶栏 ===== */
.top{display:flex;align-items:center;padding:.875rem 1.125rem;gap:.625rem;border-bottom:1px solid #1f3348;font-size:.875rem;flex-shrink:0;}
.top .bk{font-size:1.25rem;opacity:.7;cursor:pointer;}
.top .mi{flex:1;text-align:center;font-weight:600;font-size:1rem;}
.top .ri{color:#7a94b0;font-size:.875rem;min-width:2.5rem;text-align:right;}

/* ===== 跟练页 ===== */
.p-inner{flex:1;display:flex;flex-direction:column;align-items:center;padding:1.25rem;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;}

.ei{text-align:center;margin-bottom:.25rem;flex-shrink:0;}
.ei .en{font-size:1.375rem;font-weight:700;}
.ei .inf{font-size:.8125rem;color:#5a7a98;}

.sn{font-size:.8125rem;color:#5a7a98;flex-shrink:0;margin-bottom:.75rem;}
.sn .st{color:#c8d6e5;margin-left:.25rem;}

/* 画布 */
.cv{width:12.5rem;height:12.5rem;background:#1a2b3c;border-radius:.875rem;position:relative;flex-shrink:0;margin-bottom:.5rem;}
#pc{width:100%;height:100%;display:block;}
.cv .tm{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;pointer-events:none;}
.cv .tm .n{font-size:2.25rem;font-weight:200;color:#4fc3f7;line-height:1;}
.cv .tm .l{font-size:.875rem;color:#5a7a98;}

/* 步骤点 */
.dots{display:flex;gap:.375rem;flex-shrink:0;margin:.25rem 0;}
.dots div{width:.5rem;height:.5rem;border-radius:50%;background:#1f3348;transition:.2s;}
.dots .act{background:#4fc3f7;transform:scale(1.2);}
.dots .dn{background:#a5d6a7;}

/* 步骤卡片 */
.sc{width:100%;background:#1a2b3c;border-radius:.75rem;padding:.875rem 1rem;border:1px solid #1f3348;font-size:.8125rem;color:#8aa0b8;flex-shrink:0;}
.sc .tg2{display:inline-block;background:#2d4c6e;padding:.125rem .5rem;border-radius:.25rem;margin-top:.25rem;font-size:.75rem;color:#a0c4e8;}

/* 底部区域 */
.bot{width:100%;max-width:21.25rem;display:flex;flex-direction:column;gap:.5rem;flex-shrink:0;padding-bottom:.5rem;margin-top:.5rem;}

/* 按钮 */
.act{width:100%;display:flex;flex-direction:column;gap:.5rem;flex-shrink:0;}
.act .r1{display:flex;gap:.5rem;}
.act .r1 .b{flex:1;padding:.9375rem;border:none;border-radius:.75rem;font-size:.9375rem;font-weight:600;text-align:center;cursor:pointer;transition:.12s;}
.act .r1 .b:active{transform:scale(.97);}
.bp{background:linear-gradient(135deg,#4fc3f7,#29b6f6);color:#0f1923;}
.bp:disabled{opacity:.3;cursor:not-allowed;transform:none;}
.bs{background:#1f3348;color:#8aa0b8;}
.bo{padding:.875rem;border-radius:.75rem;border:1px solid #2d4c6e;background:transparent;color:#8aa0b8;font-size:.9375rem;font-weight:600;text-align:center;cursor:pointer;transition:.12s;}
.bo:active{background:#1f3348;}

/* ===== 弹窗 ===== */
.ol,.cf{display:none;position:fixed;inset:0;z-index:100;align-items:center;justify-content:center;}
.ol.show,.cf.show{display:flex;}
.ol{background:rgba(15,25,35,.95);flex-direction:column;gap:.75rem;}
.ol .oi{font-size:3.5rem;}
.ol .ot{font-size:1.25rem;font-weight:700;color:#a5d6a7;text-align:center;}
.ol .os{font-size:.875rem;color:#7a94b0;text-align:center;max-width:18.75rem;}
.ol .od{font-size:.8125rem;color:#5a7a98;text-align:center;line-height:1.6;}
.ol-btn{display:flex;gap:.625rem;width:18.75rem;padding:0;}
.ol-btn .b{flex:1;padding:.875rem;border:none;border-radius:.75rem;font-size:.9375rem;font-weight:600;cursor:pointer;text-align:center;}

.cf{background:rgba(15,25,35,.92);}
.cf .bx{background:#1a2b3c;border-radius:1rem;padding:1.75rem 1.5rem;border:1px solid #1f3348;text-align:center;max-width:18.75rem;}
.cf .bx .ct{font-size:1.125rem;font-weight:600;margin-bottom:.375rem;}
.cf .bx .cs{font-size:.8125rem;color:#7a94b0;margin-bottom:1rem;}
.cf .bx .cr{display:flex;gap:.625rem;}
.cf .bx .cr .b{flex:1;padding:.75rem;border:none;border-radius:.625rem;font-size:.9375rem;font-weight:600;cursor:pointer;}

/* ===== 姓名编辑弹窗 ===== */
.ne{display:none;position:fixed;inset:0;z-index:110;align-items:center;justify-content:center;background:rgba(15,25,35,.92);}
.ne.show{display:flex;}
.ne .bx{background:#1a2b3c;border-radius:1rem;padding:1.75rem 1.5rem;border:1px solid #1f3348;text-align:center;max-width:18.75rem;width:85%;}
.ne .bx .ct{font-size:1.125rem;font-weight:600;margin-bottom:.5rem;}
.ne .bx .ni{width:100%;padding:.6875rem .75rem;border-radius:.5rem;border:1px solid #2d4c6e;background:#0f1923;color:#e8edf2;font-size:.9375rem;text-align:center;margin-bottom:1rem;outline:none;}
.ne .bx .ni:focus{border-color:#4fc3f7;}
.ne .bx .cr{display:flex;gap:.625rem;}
.ne .bx .cr .b{flex:1;padding:.75rem;border:none;border-radius:.625rem;font-size:.9375rem;font-weight:600;cursor:pointer;}

/* ===== 删除确认弹窗 ===== */
.dc{display:none;position:fixed;inset:0;z-index:120;align-items:center;justify-content:center;background:rgba(15,25,35,.92);}
.dc.show{display:flex;}
.dc .bx{background:#1a2b3c;border-radius:1rem;padding:1.75rem 1.5rem;border:1px solid #1f3348;text-align:center;max-width:18.75rem;}
.dc .bx .ct{font-size:1.125rem;font-weight:600;margin-bottom:.375rem;}
.dc .bx .cs{font-size:.8125rem;color:#7a94b0;margin-bottom:1rem;}
.dc .bx .cr{display:flex;gap:.625rem;}
.dc .bx .cr .b{flex:1;padding:.75rem;border:none;border-radius:.625rem;font-size:.9375rem;font-weight:600;cursor:pointer;}

/* ===== 管理页 ===== */
.mg-tabs{display:flex;gap:.375rem;margin-bottom:.875rem;}
.mg-tab{flex:1;padding:.625rem;border-radius:.5rem;text-align:center;background:#1a2b3c;border:1px solid #1f3348;color:#8aa0b8;font-size:.8125rem;cursor:pointer;transition:.12s;}
.mg-tab:active{background:#1f3348;}
.mg-tab.ac{background:#2d4c6e;border-color:#4fc3f7;color:#4fc3f7;}

/* 管理页 - 项目列表 */
.mg-list{display:flex;flex-direction:column;gap:.5rem;margin-bottom:.875rem;}
.mg-item{display:flex;align-items:center;gap:.625rem;padding:.75rem .875rem;border-radius:.625rem;background:#1a2b3c;border:1px solid #1f3348;}
.mg-item .ic{font-size:1.125rem;width:1.5rem;text-align:center;flex-shrink:0;}
.mg-item .inf{flex:1;font-size:.875rem;}
.mg-item .inf .n{font-weight:600;}
.mg-item .inf .det{font-size:.75rem;color:#5a7a98;}
.mg-item .mg-acts{display:flex;gap:.25rem;flex-shrink:0;}
.mg-item .mg-acts span{font-size:.8125rem;padding:.25rem .375rem;border-radius:.25rem;cursor:pointer;opacity:.6;transition:.12s;}
.mg-item .mg-acts span:active{opacity:1;background:#1f3348;}

/* 管理页 - 分类管理 */
.mg-cat{display:flex;align-items:center;gap:.625rem;padding:.625rem .875rem;border-radius:.5rem;background:#1a2b3c;border:1px solid #1f3348;margin-bottom:.375rem;}
.mg-cat .ic{font-size:1rem;width:1.25rem;text-align:center;}
.mg-cat .n{flex:1;font-size:.875rem;}
.mg-cat .del{font-size:.75rem;padding:.25rem .375rem;border-radius:.25rem;cursor:pointer;opacity:.5;transition:.12s;color:#ef5350;}
.mg-cat .del:active{opacity:1;background:#3d1a1a;}

.mg-add-cat{display:flex;gap:.5rem;margin-top:.625rem;}
.mg-add-cat .mg-input{flex:1;padding:.625rem .75rem;border-radius:.5rem;border:1px solid #2d4c6e;background:#0f1923;color:#e8edf2;font-size:.875rem;outline:none;}
.mg-add-cat .mg-input:focus{border-color:#4fc3f7;}
.mg-add-cat .mg-input::placeholder{color:#4a6a88;}
.mg-add-cat .ic-t{max-width:3rem;text-align:center;}
.mg-add-cat .add-btn{padding:.625rem 1rem;border:none;border-radius:.5rem;background:linear-gradient(135deg,#4fc3f7,#29b6f6);color:#0f1923;font-size:.875rem;font-weight:600;cursor:pointer;flex-shrink:0;}
.mg-add-cat .add-btn:active{transform:scale(.97);}

/* 空状态 */
.empty-state{text-align:center;padding:2rem 0;color:#5a7a98;font-size:.875rem;line-height:1.6;}

/* ===== 编辑器 ===== */
.me-form{display:flex;flex-direction:column;gap:.875rem;}
.me-row{display:flex;flex-direction:column;gap:.25rem;}
.me-row label{font-size:.8125rem;color:#7a94b0;}
.me-input{padding:.6875rem .75rem;border-radius:.5rem;border:1px solid #2d4c6e;background:#0f1923;color:#e8edf2;font-size:.9375rem;outline:none;}
.me-input:focus{border-color:#4fc3f7;}
.me-input::placeholder{color:#4a6a88;}
select.me-input{appearance:auto;}

.me-type{display:flex;gap:.5rem;}
.me-type-btn{flex:1;padding:.625rem;border-radius:.5rem;text-align:center;border:1px solid #2d4c6e;background:#1a2b3c;color:#8aa0b8;font-size:.875rem;cursor:pointer;transition:.12s;}
.me-type-btn:active{background:#1f3348;}
.me-type-btn.ac{background:#2d4c6e;border-color:#4fc3f7;color:#4fc3f7;}

/* 编辑器 - 步骤 */
.steps-title{font-size:.875rem;font-weight:600;color:#8aa0b8;margin-top:.5rem;}
.me-step{background:#1a2b3c;border-radius:.5rem;padding:.75rem;border:1px solid #1f3348;margin-bottom:.5rem;}
.me-step .hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:.375rem;}
.me-step .hdr .label{font-size:.75rem;color:#5a7a98;}
.me-step .hdr .rm{font-size:.75rem;padding:.125rem .375rem;border-radius:.25rem;cursor:pointer;opacity:.5;transition:.12s;color:#ef5350;}
.me-step .hdr .rm:active{opacity:1;background:#3d1a1a;}
.me-step .sf{display:flex;flex-direction:column;gap:.375rem;}
.me-step .sf .srow{display:flex;gap:.375rem;align-items:center;}
.me-step .sf .srow input{flex:1;padding:.5rem .625rem;border-radius:.375rem;border:1px solid #2d4c6e;background:#0f1923;color:#e8edf2;font-size:.8125rem;outline:none;}
.me-step .sf .srow input:focus{border-color:#4fc3f7;}
.me-step .sf .srow input::placeholder{color:#4a6a88;}
.me-step .sf .srow .dur{max-width:4rem;text-align:center;}

.add-step-btn{width:100%;padding:.6875rem;border:1px dashed #2d4c6e;background:transparent;border-radius:.5rem;color:#5a7a98;font-size:.8125rem;cursor:pointer;transition:.12s;}
.add-step-btn:active{background:#1a2b3c;color:#8aa0b8;}
</style>
</head>
<body>

<!-- ========== 首页 ========== -->
<div class="page active" id="pH">
  <div class="scroll">
    <div class="title">✅ 每日打卡</div>
    <div class="hello" id="gr">
      <span id="grTxt">🌅 早上好，小伙伴</span>
      <span class="ne-btn" onclick="openNE()">✏️</span>
    </div>

    <div class="pc">
      <div class="r"><span>今日完成</span><span class="n" id="pgN">0 / 0</span></div>
      <div class="pb"><div class="f" id="pgB" style="width:0%"></div></div>
      <div class="sub" id="pgT">点击打卡项开始</div>
    </div>

    <div class="tags" id="tgS"></div>

    <div class="el" id="exL"></div>

    <div class="mg-entry">
      <button onclick="openMg()">📋 管理打卡项目</button>
      <button onclick="resetToday()">🔄 重置今日</button>
    </div>

    <div class="us">
      <div class="ut">💡 使用说明</div>
      每个打卡项目可设为"跟练型"（有步骤引导）或"纯打卡"（一键完成）。你可以在管理页创建自己的打卡项目。
    </div>
  </div>
</div>

<!-- ========== 跟练页 ========== -->
<div class="page" id="pP">
  <div class="top">
    <span class="bk" onclick="cfExit()">✕</span>
    <span class="mi" id="pTi">练习</span>
    <span class="ri" id="pPd"></span>
  </div>
  <div class="p-inner">

    <div class="ei">
      <div class="en" id="pEn">⛏️ 交叉爬行</div>
      <div class="inf" id="pIf">反射整合 · 约2分钟</div>
    </div>

    <div class="sn"><span id="pSn">准备</span> <span class="st" id="pSt"></span></div>

    <div class="cv">
      <canvas id="pc" width="200" height="200"></canvas>
      <div class="tm"><div class="n" id="pTim"></div><div class="l" id="pTimL"></div></div>
    </div>

    <div class="dots" id="pDt"></div>

    <div class="bot">
      <div class="sc" id="pSc"></div>
      <div class="act">
        <div class="r1">
          <button class="b bs" onclick="resetP()">🔄 重来</button>
          <button class="b bp" id="pBtn" disabled>▶ 开始</button>
        </div>
        <button class="bo" onclick="doneP()">✅ 我做完了（跳过跟练）</button>
      </div>
    </div>

  </div>
</div>

<!-- ========== 管理页 ========== -->
<div class="page" id="pM">
  <div class="top">
    <span class="bk" onclick="goH()">✕</span>
    <span class="mi">✅ 打卡管理</span>
    <span class="ri"></span>
  </div>
  <div class="scroll">
    <div class="mg-tabs">
      <span class="mg-tab ac" data-tab="items" onclick="swMg('items')">📋 打卡项目</span>
      <span class="mg-tab" data-tab="cats" onclick="swMg('cats')">🏷️ 分类管理</span>
    </div>

    <!-- 项目列表 -->
    <div id="mgItems">
      <div class="mg-list" id="mgItemList"></div>
      <button class="bo" onclick="openEditor()">➕ 新建打卡项目</button>
    </div>

    <!-- 分类管理 -->
    <div id="mgCats" style="display:none">
      <div id="mgCatList"></div>
      <div class="mg-add-cat">
        <input class="mg-input ic-t" id="catIc" placeholder="📌" maxlength="2">
        <input class="mg-input" id="catN" placeholder="分类名称">
        <button class="add-btn" onclick="addCat()">添加</button>
      </div>
    </div>
  </div>
</div>

<!-- ========== 项目编辑器 ========== -->
<div class="page" id="pME">
  <div class="top">
    <span class="bk" onclick="closeEditor()">✕</span>
    <span class="mi" id="meTitle">新建打卡项目</span>
    <span class="ri" onclick="saveItem()" style="color:#4fc3f7;cursor:pointer;">保存</span>
  </div>
  <div class="scroll">
    <div class="me-form">
      <div class="me-row">
        <label>图标</label>
        <input class="me-input" id="meIc" placeholder="如：✅" maxlength="2">
      </div>
      <div class="me-row">
        <label>名称</label>
        <input class="me-input" id="meN" placeholder="打卡项目名称">
      </div>
      <div class="me-row">
        <label>分类</label>
        <select class="me-input" id="meC"></select>
      </div>
      <div class="me-row">
        <label>类型</label>
        <div class="me-type">
          <span class="me-type-btn" data-t="routine" onclick="swType('routine')">跟练型</span>
          <span class="me-type-btn ac" data-t="simple" onclick="swType('simple')">纯打卡</span>
        </div>
      </div>
      <div class="me-row">
        <label>时长</label>
        <input class="me-input" id="meT" placeholder="如：2min">
      </div>
      <div class="me-row">
        <label>备注（可选）</label>
        <input class="me-input" id="meNo" placeholder="如：需瑜伽球、洗漱时做">
      </div>
      <div class="me-row">
        <label>循环次数（跟练型）</label>
        <input class="me-input" id="meCy" type="number" min="1" placeholder="1" value="1">
      </div>
      <div id="meSteps">
        <div class="steps-title">📝 步骤</div>
        <div id="meStepList"></div>
        <button class="add-step-btn" onclick="addStep()">➕ 添加步骤</button>
      </div>
    </div>
  </div>
</div>

<!-- ========== 完成弹窗 ========== -->
<div class="ol" id="ol">
  <div class="oi">🎉</div>
  <div class="ot" id="olT">完成！</div>
  <div class="os" id="olS"></div>
  <div class="od" id="olD"></div>
  <div class="ol-btn">
    <button class="b bs" onclick="clOl();goH()">🏠 首页</button>
    <button class="b bp" onclick="clOl();goH()">📋 继续任务</button>
  </div>
</div>

<!-- ========== 退出确认 ========== -->
<div class="cf" id="cf">
  <div class="bx">
    <div class="ct">退出练习？</div>
    <div class="cs">进度不会丢失，下次继续</div>
    <div class="cr">
      <button class="b bs" onclick="clCf()" style="background:#1f3348;color:#8aa0b8;">留在这里</button>
